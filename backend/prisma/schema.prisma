  paidAt    DateTime?     @map("paid_at")
  createdAt DateTime      @default(now()) @map("created_at")

  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([status])
  @@map("payments")
}

model ShopReceiptSetting {
  id          String   @id @default(cuid())
  shopId      String   @unique @map("shop_id")
  printerType String?  @map("printer_type") @db.VarChar(80)
  paperSize   String?  @map("paper_size") @db.VarChar(40)
  showLogo    Boolean  @default(false) @map("show_logo")
  showAddress Boolean  @default(true) @map("show_address")
  showPhone   Boolean  @default(true) @map("show_phone")
  showVatInfo Boolean  @default(false) @map("show_vat_info")
  headerText  String?  @map("header_text")
  footerText  String?  @map("footer_text")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_receipt_settings")
}
