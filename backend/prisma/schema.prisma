generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
}

enum AppType {
  WEB
  MOBILE
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  GRACE
  BLOCKED
}

enum ShopRole {
  SHOP_OWNER
  SALESMAN
}

enum OtpPurpose {
  LOGIN
  REGISTRATION
  PASSWORD_RESET
  PIN_SETUP
}

enum OtpChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  CONSUMED
  CANCELLED
}

enum UserPinStatus {
  ACTIVE
  RESET_REQUIRED
  LOCKED
  DISABLED
}

enum PasswordResetStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

enum RegistrationDraftStatus {
  PENDING
  OTP_SENT
  OTP_VERIFIED
  PIN_SET
  COMPLETED
  CANCELLED
  EXPIRED
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CategoryLogAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ARCHIVED
  RESTORED
  DELETE_BLOCKED
}

enum MasterProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ShopProductSource {
  MASTER
  SHOP_LOCAL
}

enum MasterProductRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BrandStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UnitStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UnitType {
  COUNTABLE
  WEIGHT
  VOLUME
  PACKAGING
  LENGTH
  AREA
}

enum BarcodeStatus {
  MAPPED
  UNMAPPED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  SUSPENDED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum ProductTemplateStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MoneyBoxType {
  CASH
  BKASH
  NAGAD
}

enum MoneyBoxStatus {
  ACTIVE
  INACTIVE
}

enum BankAccountType {
  CURRENT
  SAVINGS
}

enum BankAccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum InventoryMode {
  GENERAL
  RACK
}

enum InventoryBinStatus {
  EMPTY
  LOW
  FULL
  EXPIRED
}

enum SupplierLedgerEntryType {
  OPENING_DUE
  PURCHASE
  PURCHASE_RETURN
  PAYMENT
  ADJUSTMENT
}

enum PurchaseReturnStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum CustomerLedgerEntryType {
  OPENING_DUE
  SALE
  PAYMENT
  ADJUSTMENT
}

model User {
  id              String         @id @default(cuid())
  name            String         @db.VarChar(120)
  phone           String?        @unique @db.VarChar(30)
  email           String?        @unique @db.VarChar(150)
  profileImageUrl String?        @map("profile_image_url")
  passwordHash    String         @map("password_hash")
  status          UserStatus     @default(ACTIVE)
  phoneVerifiedAt DateTime?      @map("phone_verified_at")
  lastLoginAt     DateTime?      @map("last_login_at")
  createdByUserId String?        @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  createdBy       User?          @relation("UserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdUsers    User[]         @relation("UserCreator")
  platformUser    PlatformUser?
  ownedShops      Shop[]         @relation("ShopOwner")
  shopUsers       ShopUser[]
  refreshTokens   RefreshToken[]
  pin             UserPin?
  otpVerifications OtpVerification[]
  passwordResetRequests PasswordResetRequest[]
  purchasesCreated Purchase[] @relation("PurchaseCreatedBy")
  purchasesApproved Purchase[] @relation("PurchaseApprovedBy")
  purchaseReturnsCreated PurchaseReturn[] @relation("PurchaseReturnCreatedBy")
  purchaseReturnsApproved PurchaseReturn[] @relation("PurchaseReturnApprovedBy")
  categoriesCreated ProductCategory[] @relation("CategoryCreatedBy")
  categoriesUpdated ProductCategory[] @relation("CategoryUpdatedBy")
  categoryLogsPerformed CategoryLog[] @relation("CategoryLogPerformedBy")
  masterProductsCreated MasterProduct[] @relation("MasterProductCreatedBy")
  masterProductsUpdated MasterProduct[] @relation("MasterProductUpdatedBy")
  masterProductRequestsCreated MasterProductRequest[] @relation("MasterProductRequestCreatedBy")
  masterProductRequestsReviewed MasterProductRequest[] @relation("MasterProductRequestReviewedBy")
  brandsCreated     Brand[]        @relation("BrandCreatedBy")
  brandsUpdated     Brand[]        @relation("BrandUpdatedBy")
  barcodesCreated   MasterProductBarcode[] @relation("BarcodeCreatedBy")
  barcodesUpdated   MasterProductBarcode[] @relation("BarcodeUpdatedBy")

  @@map("users")
}

model PlatformUser {
  id        String       @id @default(cuid())
  userId    String       @unique @map("user_id")
  role      PlatformRole
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_users")
}

model Shop {
  id              String      @id @default(cuid())
  shopCode        String?     @unique @map("shop_code") @db.VarChar(30)
  shopName        String      @map("shop_name") @db.VarChar(150)
  ownerUserId     String?     @map("owner_user_id")
  phone           String?     @db.VarChar(30)
  email           String?     @db.VarChar(150)
  businessType    String?     @map("business_type") @db.VarChar(80)
  logoUrl         String?     @map("logo_url")
  address         String?
  area            String?     @db.VarChar(100)
  district        String?     @db.VarChar(100)
  postalCode      String?     @map("postal_code") @db.VarChar(20)
  openingTime     String?     @map("opening_time") @db.VarChar(20)
  closingTime     String?     @map("closing_time") @db.VarChar(20)
  weeklyHoliday   String?     @map("weekly_holiday") @db.VarChar(30)
  tradeLicenseNo  String?     @map("trade_license_no") @db.VarChar(100)
  tinNo           String?     @map("tin_no") @db.VarChar(100)
  vatRegNo        String?     @map("vat_reg_no") @db.VarChar(100)
  status          ShopStatus  @default(ACTIVE)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  owner           User?       @relation("ShopOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  shopUsers       ShopUser[]
  subscription    Subscription?
  invoices        Invoice[]
  payments        Payment[]
  purchases       Purchase[]
  shopProducts    ShopProduct[]
  moneyBoxes      MoneyBox[]
  bankAccounts    BankAccount[]
  customerSales   CustomerSale[]
  customerPayments CustomerPayment[]
  expenses        Expense[]
  customerLedgers CustomerLedger[]
  supplierPayments SupplierPayment[]
  supplierLedgers SupplierLedger[]
  purchaseReturns  PurchaseReturn[]
  receiptSetting  ShopReceiptSetting?
  otpVerifications OtpVerification[]
  passwordResetRequests PasswordResetRequest[]
  registrationDrafts OwnerRegistrationDraft[]
  inventorySetting ShopInventorySetting?
  inventoryZones  InventoryZone[]
  inventoryRacks  InventoryRack[]
  inventoryShelves InventoryShelf[]
  inventoryBins   InventoryBin[]
  inventoryBinItems InventoryBinItem[]
  masterProductRequests MasterProductRequest[]

  @@index([shopName])
  @@map("shops")
}

model ShopUser {
  id             String    @id @default(cuid())
  shopId         String    @map("shop_id")
  userId         String    @map("user_id")
  role           ShopRole  @default(SALESMAN)
  isBillable     Boolean   @default(true) @map("is_billable")
  createdAt      DateTime  @default(now()) @map("created_at")

  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesmanPermission SalesmanPermission?

  @@unique([shopId, userId])
  @@index([shopId, role])
  @@map("shop_users")
}

model SalesmanPermission {
  id             String   @id @default(cuid())
  shopUserId     String   @unique @map("shop_user_id")
  canSell        Boolean  @default(false) @map("can_sell")
  canViewStock   Boolean  @default(false) @map("can_view_stock")
  canViewReports Boolean  @default(false) @map("can_view_reports")
  canChangePrice Boolean  @default(false) @map("can_change_price")
  canCollectDue  Boolean  @default(false) @map("can_collect_due")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  shopUser       ShopUser @relation(fields: [shopUserId], references: [id], onDelete: Cascade)

  @@map("salesman_permissions")
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  family       String
  appType      AppType   @map("app_type")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, family])
  @@index([family])
  @@map("refresh_tokens")
}

model OtpVerification {
  id           String     @id @default(cuid())
  userId       String?    @map("user_id")
  shopId       String?    @map("shop_id")
  appType      AppType    @map("app_type")
  purpose      OtpPurpose
  channel      OtpChannel @default(SMS)
  recipient    String     @db.VarChar(160)
  countryCode  String?    @map("country_code") @db.VarChar(8)
  codeHash     String     @map("code_hash")
  attempts     Int        @default(0)
  maxAttempts  Int        @default(5) @map("max_attempts")
  sentAt       DateTime   @default(now()) @map("sent_at")
  expiresAt    DateTime   @map("expires_at")
  verifiedAt   DateTime?  @map("verified_at")
  consumedAt   DateTime?  @map("consumed_at")
  status       OtpStatus  @default(PENDING)
  requestIp    String?    @map("request_ip") @db.VarChar(64)
  createdAt    DateTime   @default(now()) @map("created_at")

  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  shop         Shop?      @relation(fields: [shopId], references: [id], onDelete: SetNull)
  passwordResetRequest PasswordResetRequest?
  registrationDraft OwnerRegistrationDraft?

  @@index([recipient, purpose, status])
  @@index([userId, purpose, status])
  @@index([shopId, purpose, status])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model UserPin {
  id            String        @id @default(cuid())
  userId        String        @unique @map("user_id")
  pinHash       String        @map("pin_hash")
  status        UserPinStatus @default(ACTIVE)
  failedAttempts Int          @default(0) @map("failed_attempts")
  lockedUntil   DateTime?     @map("locked_until")
  lastChangedAt DateTime      @default(now()) @map("last_changed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("user_pins")
}

model PasswordResetRequest {
  id                String              @id @default(cuid())
  userId            String              @map("user_id")
  shopId            String?             @map("shop_id")
  appType           AppType             @map("app_type")
  otpVerificationId String?             @unique @map("otp_verification_id")
  requestedFor      String              @map("requested_for") @db.VarChar(160)
  status            PasswordResetStatus @default(PENDING)
  expiresAt         DateTime            @map("expires_at")
  completedAt       DateTime?           @map("completed_at")
  createdAt         DateTime            @default(now()) @map("created_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop              Shop?               @relation(fields: [shopId], references: [id], onDelete: SetNull)
  otpVerification   OtpVerification?    @relation(fields: [otpVerificationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([shopId, status])
  @@index([expiresAt])
  @@map("password_reset_requests")
}

model OwnerRegistrationDraft {
  id                String                  @id @default(cuid())
  name              String                  @db.VarChar(120)
  mobile            String                  @db.VarChar(30)
  email             String?                 @db.VarChar(150)
  passwordHash      String                  @map("password_hash")
  shopId            String?                 @map("shop_id")
  shopName          String                  @map("shop_name") @db.VarChar(150)
  shopAddress       String                  @map("shop_address")
  shopCategory      String                  @map("shop_category") @db.VarChar(120)
  shopLocationLabel String?                 @map("shop_location_label") @db.VarChar(160)
  latitude          Decimal?                @db.Decimal(10, 7)
  longitude         Decimal?                @db.Decimal(10, 7)
  otpVerificationId String?                 @unique @map("otp_verification_id")
  pinHash           String?                 @map("pin_hash")
  otpVerifiedAt     DateTime?               @map("otp_verified_at")
  pinSetAt          DateTime?               @map("pin_set_at")
  completedAt       DateTime?               @map("completed_at")
  status            RegistrationDraftStatus @default(PENDING)
  expiresAt         DateTime                @map("expires_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  shop              Shop?                   @relation(fields: [shopId], references: [id], onDelete: SetNull)
  otpVerification   OtpVerification?        @relation(fields: [otpVerificationId], references: [id], onDelete: SetNull)

  @@index([mobile, status])
  @@index([shopName, status])
  @@index([expiresAt])
  @@map("owner_registration_drafts")
}

model ProductCategory {
  id              String         @id @default(cuid())
  name            String         @unique @db.VarChar(120)
  description     String?
  status          CategoryStatus @default(ACTIVE)
  createdByUserId String?        @map("created_by")
  updatedByUserId String?        @map("updated_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  createdBy       User?          @relation("CategoryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?          @relation("CategoryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  masterProducts  MasterProduct[]
  logs            CategoryLog[]

  @@index([status])
  @@map("product_categories")
}

model MasterProduct {
  id              String              @id @default(cuid())
  sku             String              @unique @db.VarChar(60)
  name            String              @db.VarChar(160)
  description     String?
  categoryId      String?             @map("category_id")
  brandId         String?             @map("brand_id")
  unitId          String?             @map("unit_id")
  price           Decimal?            @map("price") @db.Decimal(10, 2)
  suggestedPrice  Decimal?            @map("suggested_price") @db.Decimal(10, 2)
  packageSize     String?             @map("package_size") @db.VarChar(80)
  pictureUrl      String?             @map("picture_url")
  status          MasterProductStatus @default(ACTIVE)
  createdByUserId String?             @map("created_by")
  updatedByUserId String?             @map("updated_by")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  category        ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit            Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdBy       User?               @relation("MasterProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?               @relation("MasterProductUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  barcodes        MasterProductBarcode[]
  templateItems   ProductTemplateItem[]
  purchaseItems   PurchaseItem[]
  purchaseReturnItems PurchaseReturnItem[]
  customerSaleItems CustomerSaleItem[]
  shopProducts    ShopProduct[]
  inventoryBinItems InventoryBinItem[]
  approvalRequests MasterProductRequest[]

  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([status])
  @@map("master_products")
}

model Brand {
  id              String       @id @default(cuid())
  name            String       @unique @db.VarChar(120)
  description     String?
  logoUrl         String?      @map("logo_url")
  status          BrandStatus  @default(ACTIVE)
  createdByUserId String?      @map("created_by")
  updatedByUserId String?      @map("updated_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  masterProducts  MasterProduct[]
  createdBy       User?        @relation("BrandCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?        @relation("BrandUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("brands")
}

model Unit {
  id          String     @id @default(cuid())
  name        String     @unique @db.VarChar(120)
  shortName   String     @unique @map("short_name") @db.VarChar(40)
  type        UnitType
  description String?
  status      UnitStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  masterProducts MasterProduct[]

  @@index([status])
  @@index([type])
  @@map("units")
}

model MasterProductBarcode {
  id              String         @id @default(cuid())
  masterProductId String?        @map("master_product_id")
  barcode         String         @unique @db.VarChar(80)
  packSize        String?        @map("pack_size") @db.VarChar(80)
  status          BarcodeStatus  @default(UNMAPPED)
  createdByUserId String?        @map("created_by")
  updatedByUserId String?        @map("updated_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id], onDelete: SetNull)
  createdBy       User?          @relation("BarcodeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?          @relation("BarcodeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([masterProductId])
  @@index([status])
  @@map("master_product_barcodes")
}

model ProductTemplate {
  id          String                @id @default(cuid())
  code        String                @unique @db.VarChar(80)
  name        String                @db.VarChar(160)
  description String?
  status      ProductTemplateStatus @default(ACTIVE)
  products    ProductTemplateItem[]
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@map("product_templates")
}

model ShopProduct {
  id              String         @id @default(cuid())
  shopId          String         @map("shop_id")
  masterProductId String?        @map("master_product_id")
  source          ShopProductSource @default(MASTER)
  localName       String?        @map("local_name") @db.VarChar(160)
  localCategory   String?        @map("local_category") @db.VarChar(120)
  localBrand      String?        @map("local_brand") @db.VarChar(120)
  localUnit       String?        @map("local_unit") @db.VarChar(60)
  localBarcode    String?        @map("local_barcode") @db.VarChar(120)
  localPictureUrl String?        @map("local_picture_url")
  lowStockLimit   Decimal        @default(0) @map("low_stock_limit") @db.Decimal(12, 3)
  approvalRequestId String?      @map("approval_request_id")
  openingStock    Decimal        @default(0) @map("opening_stock") @db.Decimal(12, 3)
  salePrice       Decimal?       @map("sale_price") @db.Decimal(10, 2)
  purchasePrice   Decimal?       @map("purchase_price") @db.Decimal(10, 2)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  shop            Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  masterProduct   MasterProduct? @relation(fields: [masterProductId], references: [id], onDelete: Cascade)
  approvalRequest MasterProductRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@unique([shopId, masterProductId])
  @@index([shopId])
  @@index([masterProductId])
  @@index([approvalRequestId])
  @@map("shop_products")
}

model MasterProductRequest {
  id               String                   @id @default(cuid())
  shopId           String                   @map("shop_id")
  shopProductId    String?                  @map("shop_product_id")
  createdByUserId  String?                  @map("created_by_user_id")
  reviewedByUserId String?                  @map("reviewed_by_user_id")
  masterProductId  String?                  @map("master_product_id")
  name             String                   @db.VarChar(160)
  category         String?                  @db.VarChar(120)
  brand            String?                  @db.VarChar(120)
  unit             String?                  @db.VarChar(60)
  barcode          String?                  @db.VarChar(120)
  pictureUrl       String?
  purchasePrice    Decimal?                 @map("purchase_price") @db.Decimal(10, 2)
  salePrice        Decimal?                 @map("sale_price") @db.Decimal(10, 2)
  openingStock     Decimal                  @default(0) @map("opening_stock") @db.Decimal(12, 3)
  lowStockLimit    Decimal                  @default(0) @map("low_stock_limit") @db.Decimal(12, 3)
  status           MasterProductRequestStatus @default(PENDING)
  rejectionReason  String?                  @map("rejection_reason")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  shop             Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopProduct      ShopProduct[]           
  createdBy        User?                    @relation("MasterProductRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedBy       User?                    @relation("MasterProductRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  masterProduct    MasterProduct?           @relation(fields: [masterProductId], references: [id], onDelete: SetNull)

  @@index([shopId, status])
  @@index([masterProductId])
  @@map("master_product_requests")
}

model ShopInventorySetting {
  id                    String        @id @default(cuid())
  shopId                String        @unique @map("shop_id")
  mode                  InventoryMode @default(GENERAL)
  lowStockDefault       Int           @default(10) @map("low_stock_default")
  lowStockGrocery       Int           @default(5) @map("low_stock_grocery")
  autoLowStockAlert     Boolean       @default(true) @map("auto_low_stock_alert")
  reduceStockOnSale     Boolean       @default(true) @map("reduce_stock_on_sale")
  allowNegativeStock    Boolean       @default(false) @map("allow_negative_stock")
  requireBinAssignment  Boolean       @default(false) @map("require_bin_assignment")
  showBinDuringSale     Boolean       @default(true) @map("show_bin_during_sale")
  demandBasedReorder    Boolean       @default(false) @map("demand_based_reorder")
  manualStockApproval   Boolean       @default(false) @map("manual_stock_approval")
  stockMethod           String        @default("FIFO") @map("stock_method")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  shop                  Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_inventory_settings")
}

model InventoryZone {
  id         String    @id @default(cuid())
  shopId      String    @map("shop_id")
  name       String    @db.VarChar(120)
  subtitle   String?   @db.VarChar(255)
  icon       String?   @db.VarChar(40)
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  shop        Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  racks      InventoryRack[]
  shelves    InventoryShelf[]
  bins       InventoryBin[]

  @@unique([shopId, name])
